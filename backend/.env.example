# =====================================================================
# Kisan Sathi backend configuration
# Copy this file to ".env" and fill in your own keys.
# NEVER commit the real .env file to git.
# =====================================================================

# OpenWeather key  ->  https://home.openweathermap.org/api_keys
# Used for /weather. Subscribe to the free "Agro API" plan on the same
# account if you also want NDVI to work with this key.
OPENWEATHER_KEY=your_openweather_key_here

# AgroMonitoring key  ->  https://home.agromonitoring.com/users/api-keys
# Used for /ndvi and farm polygons (satellite crop health).
AGRO_API_KEY=your_agro_key_here

# data.gov.in key  ->  https://data.gov.in  (Generate API Key in your profile)
# Used for live mandi (market) prices.
DATA_GOV_API_KEY=your_data_gov_key_here

# data.gov.in resource id for "Current Daily Price of Various Commodities"
DATA_GOV_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070

# Optional: a default AgroMonitoring polygon id to fall back on for NDVI demos.
DEFAULT_FIELD_ID=

# Database URL. Default = local SQLite file. For production use Postgres, e.g.
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/kisansathi
DATABASE_URL=sqlite:///./kisan_sathi.db

# Comma-separated list of origins allowed to call the API (your apps).
# Use * during local development.
CORS_ORIGINS=*
